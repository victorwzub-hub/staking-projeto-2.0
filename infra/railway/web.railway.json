{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "infra/docker/web.Dockerfile",
    "watchPatterns": [
      "apps/web/**",
      "packages/contracts/**",
      "package.json",
      "package-lock.json",
      "infra/docker/web.Dockerfile"
    ]
  },
  "deploy": {
    "healthcheckPath": "/",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
