# Development-only example. Do not reuse these credentials in production.

# Runtime
APP_NAME=Pharma Intelligence SaaS
APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
READINESS_TIMEOUT_SECONDS=2.0

# PostgreSQL — intentionally insecure local credentials
POSTGRES_DB=pharma
POSTGRES_USER=pharma
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://pharma:change-me-local-only@postgres:5432/pharma

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Frontend: only NEXT_PUBLIC_* values are exposed to the browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
WEB_PORT=3000

# Worker
DRAMATIQ_PROCESSES=1
DRAMATIQ_THREADS=4
