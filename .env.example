# Development-only example. Never reuse these values in staging or production.

# Runtime
APP_NAME=Pharma Intelligence SaaS
APP_ENV=development
APP_DEBUG=false
APP_LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
FRONTEND_BASE_URL=http://localhost:3000

# API and CORS
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
READINESS_TIMEOUT_SECONDS=2.0

# PostgreSQL — intentionally insecure local credentials
POSTGRES_DB=pharma
POSTGRES_ADMIN_USER=pharma_admin
POSTGRES_ADMIN_PASSWORD=change-me-admin-local-only
POSTGRES_APP_USER=pharma_app
POSTGRES_APP_PASSWORD=change-me-app-local-only
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://pharma_app:change-me-app-local-only@postgres:5432/pharma
MIGRATION_DATABASE_URL=postgresql+psycopg://pharma_admin:change-me-admin-local-only@postgres:5432/pharma
DATABASE_APPLICATION_ROLE=pharma_app

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# Immutable landing zone (MinIO locally, any S3-compatible service in deployment)
OBJECT_STORAGE_BACKEND=s3
OBJECT_STORAGE_ROOT=/app/.local/objects
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=pharma-landing
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=pharma-minio-local
S3_SECRET_ACCESS_KEY=change-me-minio-local-only
# MinIO in the local Compose stack has no KMS; deployed S3 defaults to AES256.
S3_SERVER_SIDE_ENCRYPTION=
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
INTEGRATION_UPLOAD_MAX_BYTES=104857600
INTEGRATION_CHUNK_RECORDS=1000
INTEGRATION_RETENTION_DAYS=90
INTEGRATION_LEASE_SECONDS=300
CONNECTOR_TIMEOUT_SECONDS=60

# Password hashing (Argon2id)
PASSWORD_MIN_LENGTH=12
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST_KIB=65536
ARGON2_PARALLELISM=4
ARGON2_HASH_LEN=32
ARGON2_SALT_LEN=16

# Opaque sessions and CSRF — development placeholders only
SESSION_COOKIE_NAME=pharma_session
CSRF_COOKIE_NAME=pharma_csrf
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_SECONDS=43200
SESSION_IDLE_TIMEOUT_SECONDS=10800
SESSION_TOKEN_PEPPER=development-session-pepper-change-me
ONE_TIME_TOKEN_PEPPER=development-token-pepper-change-me

# One-time token lifetimes
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600
INVITATION_TTL_SECONDS=604800

# Login protection
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_SECONDS=900
LOGIN_LOCKOUT_SECONDS=900
LOGIN_MAX_LOCKOUT_SECONDS=86400
PUBLIC_AUTH_MAX_REQUESTS=5
PUBLIC_AUTH_WINDOW_SECONDS=900

# Development e-mail adapter
EMAIL_BACKEND=development
EMAIL_FROM_ADDRESS=no-reply@local.invalid
EMAIL_SPOOL_DIRECTORY=/app/.local/emails

# First platform administrator — disabled by default
BOOTSTRAP_ENABLED=false
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Retention
AUDIT_RETENTION_DAYS=730
SESSION_RETENTION_DAYS=180

# Frontend: only NEXT_PUBLIC_* values are exposed to the browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_API_TIMEOUT_MS=10000
WEB_PORT=3000

# Worker
DRAMATIQ_PROCESSES=1
DRAMATIQ_THREADS=4
